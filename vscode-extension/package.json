{
  "name": "duck-sqllsp-vscode",
  "displayName": "duck-sqllsp",
  "description": "SQL Language Server for Postgres (and MySQL / SQLite) -- completion, hover, diagnostics, formatting, inlay hints, refactors. Works offline; richer when a DB is connected.",
  "version": "0.1.8",
  "publisher": "wildduck",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gentleeduck/duck-sqllsp"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "sql",
    "postgres",
    "postgresql",
    "lsp",
    "language-server"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:sql",
    "onLanguage:postgres",
    "onLanguage:plpgsql",
    "onLanguage:plsql",
    "workspaceContains:**/*.sql",
    "onView:duckSqllsp.connections",
    "onCommand:duckSqllsp.addConnection",
    "onCommand:duckSqllsp.listConnections",
    "onCommand:duckSqllsp.setActiveConnection",
    "onCommand:duckSqllsp.removeConnection",
    "onCommand:duckSqllsp.refreshCatalog",
    "onCommand:duckSqllsp.restartServer",
    "onCommand:duckSqllsp.showLogs",
    "onCommand:duckSqllsp.testConnection",
    "onCommand:duckSqllsp.refreshSchema",
    "onCommand:duckSqllsp.insertColumnAtCursor",
    "onView:duckSqllsp.schema"
  ],
  "contributes": {
    "commands": [
      {
        "command": "duckSqllsp.addConnection",
        "title": "Add Connection",
        "category": "duck-sqllsp",
        "icon": "$(add)"
      },
      {
        "command": "duckSqllsp.listConnections",
        "title": "List Connections",
        "category": "duck-sqllsp",
        "icon": "$(list-unordered)"
      },
      {
        "command": "duckSqllsp.setActiveConnection",
        "title": "Set Active Connection",
        "category": "duck-sqllsp",
        "icon": "$(check)"
      },
      {
        "command": "duckSqllsp.removeConnection",
        "title": "Remove Connection",
        "category": "duck-sqllsp",
        "icon": "$(trash)"
      },
      {
        "command": "duckSqllsp.refreshCatalog",
        "title": "Refresh Catalog",
        "category": "duck-sqllsp",
        "icon": "$(refresh)"
      },
      {
        "command": "duckSqllsp.restartServer",
        "title": "Restart Server",
        "category": "duck-sqllsp",
        "icon": "$(debug-restart)"
      },
      {
        "command": "duckSqllsp.showLogs",
        "title": "Show Logs",
        "category": "duck-sqllsp",
        "icon": "$(output)"
      },
      {
        "command": "duckSqllsp.testConnection",
        "title": "Test Active Connection",
        "category": "duck-sqllsp",
        "icon": "$(zap)"
      },
      {
        "command": "duckSqllsp.refreshSchema",
        "title": "Refresh Schema Tree",
        "category": "duck-sqllsp",
        "icon": "$(refresh)"
      },
      {
        "command": "duckSqllsp.insertColumnAtCursor",
        "title": "Insert column at cursor",
        "category": "duck-sqllsp"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "duck-sqllsp",
          "title": "duck-sqllsp",
          "icon": "$(database)"
        }
      ]
    },
    "views": {
      "duck-sqllsp": [
        {
          "id": "duckSqllsp.connections",
          "name": "Connections",
          "icon": "$(database)",
          "contextualTitle": "duck-sqllsp"
        },
        {
          "id": "duckSqllsp.schema",
          "name": "Schema",
          "icon": "$(symbol-namespace)",
          "contextualTitle": "duck-sqllsp"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "duckSqllsp.refreshSchema",
          "when": "view == duckSqllsp.schema",
          "group": "navigation@1"
        },
        {
          "command": "duckSqllsp.addConnection",
          "when": "view == duckSqllsp.connections",
          "group": "navigation@1"
        },
        {
          "command": "duckSqllsp.refreshCatalog",
          "when": "view == duckSqllsp.connections",
          "group": "navigation@2"
        },
        {
          "command": "duckSqllsp.restartServer",
          "when": "view == duckSqllsp.connections",
          "group": "navigation@3"
        },
        {
          "command": "duckSqllsp.testConnection",
          "when": "view == duckSqllsp.connections",
          "group": "navigation@4"
        },
        {
          "command": "duckSqllsp.showLogs",
          "when": "view == duckSqllsp.connections",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "duckSqllsp.setActiveConnection",
          "when": "view == duckSqllsp.connections && viewItem == connection",
          "group": "inline@1"
        },
        {
          "command": "duckSqllsp.removeConnection",
          "when": "view == duckSqllsp.connections && viewItem == connection",
          "group": "inline@2"
        }
      ]
    },
    "languages": [
      {
        "id": "sql",
        "extensions": [
          ".sql",
          ".pgsql",
          ".psql"
        ],
        "aliases": [
          "SQL",
          "PostgreSQL",
          "pgsql"
        ]
      }
    ],
    "snippets": [
      {
        "language": "sql",
        "path": "./snippets/sql.json"
      }
    ],
    "walkthroughs": [
      {
        "id": "duckSqllspGetStarted",
        "title": "Get started with duck-sqllsp",
        "description": "SQL completion / hover / diagnostics / formatting for Postgres (MySQL + SQLite too). Install the server, connect a DB (or stay offline), and try it.",
        "steps": [
          {
            "id": "install",
            "title": "Install the duck-sqllsp binary",
            "description": "The extension is a thin client -- install the Rust server binary first.\n[Show Logs](command:duckSqllsp.showLogs)",
            "media": {
              "markdown": "media/install.md"
            },
            "completionEvents": [
              "onCommand:duckSqllsp.restartServer"
            ]
          },
          {
            "id": "connect",
            "title": "Connect to a database (optional)",
            "description": "Catalog-aware completion / hover get richer with a live DB connection. Open the Connections sidebar and click +.\n[Add Connection](command:duckSqllsp.addConnection)",
            "media": {
              "markdown": "media/connect.md"
            },
            "completionEvents": [
              "onCommand:duckSqllsp.addConnection"
            ]
          },
          {
            "id": "try",
            "title": "Try a SQL file",
            "description": "Open or create any .sql file and start typing -- completion, hover, diagnostics, inlay hints, and refactors all fire automatically.",
            "media": {
              "markdown": "media/try.md"
            },
            "completionEvents": [
              "onLanguage:sql"
            ]
          },
          {
            "id": "format",
            "title": "Configure formatter + rules",
            "description": "Set casing, alignment, formatter knobs, and per-rule severity in `.duck-sqllsp.toml`.",
            "media": {
              "markdown": "media/format.md"
            },
            "completionEvents": []
          }
        ]
      }
    ],
    "configuration": {
      "type": "object",
      "title": "duck-sqllsp",
      "properties": {
        "duckSqllsp.serverPath": {
          "type": "string",
          "default": "duck-sqllsp",
          "description": "Path to the duck-sqllsp binary. Use absolute path if not on PATH."
        },
        "duckSqllsp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace LSP traffic between client and server (output -> 'duck-sqllsp' channel)."
        },
        "duckSqllsp.activeConnection": {
          "type": "string",
          "default": "",
          "description": "Named connection to use for live catalog introspection. Leave blank for offline-only mode (buffer-derived catalog still works)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -p .",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --target=node18 --external:vscode --outfile=out/extension.js --format=cjs --sourcemap",
    "watch": "tsc -watch -p .",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.0"
  }
}
